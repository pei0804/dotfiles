{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Claude Codeが完了しました' -sound Glass"
          },
          {
            "type": "command",
            "command": "~/.claude/tmux-notify.sh on"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/tmux-notify.sh off"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "terraform-skill@antonbabenko": true,
    "cekernel@clonable-eden-plugins": true,
    "dbt@dbt-agent-marketplace": true
  },
  "skipDangerousModePermissionPrompt": true
}
