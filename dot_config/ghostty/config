# Ghostty Configuration

# Font
font-family = PlemolJP Console NF
font-size = 14

# Theme
theme = Catppuccin Mocha

# Window
window-padding-x = 4
window-padding-y = 4
window-decoration = auto
macos-titlebar-style = hidden

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration
shell-integration = zsh

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = false

# --------------------------------------------------
# Keybindings (vim-style)
# --------------------------------------------------

# Split creation
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Split navigation (hjkl)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right

# Split resize
keybind = cmd+ctrl+h=resize_split:left,10
keybind = cmd+ctrl+j=resize_split:down,10
keybind = cmd+ctrl+k=resize_split:up,10
keybind = cmd+ctrl+l=resize_split:right,10

# Split zoom / equalize
keybind = cmd+shift+z=toggle_split_zoom
keybind = cmd+shift+equal=equalize_splits

# Tab navigation
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5

# Scrollback vim-style navigation (Alt as modifier)
keybind = alt+j=scroll_page_lines:1
keybind = alt+k=scroll_page_lines:-1
keybind = alt+d=scroll_page_fractional:0.5
keybind = alt+u=scroll_page_fractional:-0.5
keybind = alt+g=scroll_to_top
keybind = alt+shift+g=scroll_to_bottom

# Open scrollback in $EDITOR (full vim navigation)
keybind = cmd+shift+e=write_scrollback_file:open

# Prompt navigation (requires shell integration)
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# Clipboard
keybind = performable:cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
